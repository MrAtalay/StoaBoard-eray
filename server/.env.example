# Database — Prisma uses the standard postgresql:// scheme
# (Python tarafı 'postgresql+psycopg2://' kullanıyordu; Prisma için sadece 'postgresql://')
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Session / cookie secret
SECRET_KEY="change-me-to-a-long-random-string"

# Server
PORT=5000
NODE_ENV=development

# CORS — virgülle ayır, hepsi için '*' yaz
CORS_ORIGINS=http://localhost:5000

# Google OAuth (auth.py'deki gibi)
GOOGLE_CLIENT_ID=

# Cookie güvenlik (production'da true)
SESSION_COOKIE_SECURE=false
