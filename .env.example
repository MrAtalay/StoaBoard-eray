# StoaBoard environment example
# Copy this file as .env for local development. Do not commit .env.

# Required in production. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=replace-with-a-long-random-secret

# Local default is SQLite when DATABASE_URL is empty.
# For Neon, use the connection string from the Neon dashboard.
# Keep sslmode=require for Neon.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Local development should keep this false because http://localhost is not HTTPS.
# Railway/production should set it to true.
# SESSION_COOKIE_SECURE=false

# Optional. Leave empty when frontend and backend are served by the same Flask app.
# If you later host frontend separately, set the public frontend URL here.
# Multiple origins can be comma-separated.
# CORS_ORIGINS=https://your-app.up.railway.app

# Local development on Windows/Python 3.14 should use threading.
# Railway should use eventlet.
# SOCKETIO_ASYNC_MODE=threading

# Local override.
# FLASK_ENV=development

# ── E-posta / Şifre sıfırlama ───────────────────────────────────────────────
# SMTP ayarları olmadan uygulama geliştirme modunda çalışır ve kodu sadece
# sunucu konsoluna yazar. Üretimde aşağıdaki değerleri doldurun.
#
# Gmail örneği:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=hesabiniz@gmail.com
#   SMTP_PASS=uygulama-sifresi      (Gmail → Güvenlik → Uygulama şifreleri)
#   SMTP_FROM=StoaBoard <hesabiniz@gmail.com>
#
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized JavaScript origins: http://localhost:5000 (dev), https://your-app.railway.app (prod)
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
